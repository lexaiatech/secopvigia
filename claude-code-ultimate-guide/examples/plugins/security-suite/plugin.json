{
  "name": "security-suite",
  "version": "1.0.0",
  "display_name": "Security Suite",
  "description": "Complete security hardening for Claude Code workflows. Includes security auditor agent, automated checks, pre-commit hooks, and compliance commands.",

  "author": "Claude Code Ultimate Guide",
  "license": "CC BY-SA 4.0",
  "homepage": "https://github.com/FlorianBruniaux/claude-code-ultimate-guide",

  "minimum_claude_code_version": "2.1.0",
  "compatible_models": ["claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5"],

  "install_time_estimate": "5 minutes",
  "learning_curve": "Intermediate",

  "includes": {
    "agents": [
      {
        "name": "security-auditor",
        "file": "agents/security-auditor.md",
        "description": "Specialist agent for security analysis, threat modeling, and CVE tracking"
      }
    ],
    "commands": [
      {
        "name": "security-check",
        "file": "commands/security-check.md",
        "description": "Quick 30-second security scan of your configuration"
      },
      {
        "name": "security-audit",
        "file": "commands/security-audit.md",
        "description": "Full 6-phase security audit with score /100"
      },
      {
        "name": "audit-agents-skills",
        "file": "commands/audit-agents-skills.md",
        "description": "Verify quality of agents, skills, and commands in .claude/ config"
      }
    ],
    "hooks": [
      {
        "name": "security-gate",
        "file": "hooks/security-gate.sh",
        "type": "PreToolUse",
        "description": "Block dangerous operations before execution"
      },
      {
        "name": "security-check",
        "file": "hooks/security-check.sh",
        "type": "PostToolUse",
        "description": "Validate outputs for security issues"
      }
    ],
    "templates": [
      {
        "name": "security-checklist",
        "file": "templates/security-checklist.md",
        "type": "skill",
        "description": "Automated security checklist for compliance"
      }
    ]
  },

  "install_instructions": "bash install.sh",
  "uninstall_instructions": "bash uninstall.sh",

  "documentation_links": {
    "getting_started": "README.md",
    "security_guide": "https://cc.bruniaux.com/guide/security/security-hardening/",
    "threat_database": "https://cc.bruniaux.com/guide/security/",
    "cve_tracking": "https://cc.bruniaux.com/guide/core/known-issues/"
  },

  "features": [
    "Automated security scanning",
    "Pre-commit security gates",
    "CVE and threat tracking",
    "Configuration validation",
    "Agent/skill quality audits",
    "Compliance reporting"
  ],

  "quick_start": [
    "1. Run: bash install.sh",
    "2. Test: /security-check",
    "3. Audit: /security-audit",
    "4. Review results and implement recommendations"
  ],

  "dependencies": [],
  "conflicts": [],

  "tags": ["security", "production", "compliance", "audit", "hardening"],
  "category": "Security & Compliance"
}
