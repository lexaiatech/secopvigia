{
  "name": "pr-workflow",
  "version": "1.0.0",
  "display_name": "PR Review Workflow",
  "description": "Automated pull request review system with code quality, security, and testing verification.",
  "minimum_claude_code_version": "2.1.0",
  "includes": {
    "agents": [{"name": "code-reviewer", "file": "agents/code-reviewer.md"}],
    "commands": [{"name": "review-pr", "file": "commands/review-pr.md"}, {"name": "pr", "file": "commands/pr.md"}],
    "hooks": [{"name": "pre-pr-check", "file": "hooks/bash/pre-pr-check.sh", "type": "PreToolUse"}]
  },
  "install_time_estimate": "3 minutes",
  "learning_curve": "Beginner",
  "features": ["PR automation", "Code review", "Test verification", "Compliance checks"],
  "quick_start": ["bash install.sh", "/review-pr <pr-number>", "Review automated feedback"]
}
